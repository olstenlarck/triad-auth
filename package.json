{
  "name": "triad-auth-broker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp exec astro build && node scripts/generate-csp-hashes.mjs",
    "check:config": "node scripts/check-config.mjs",
    "check:deploy": "wrangler deploy --dry-run",
    "db:local": "wrangler d1 migrations apply triad-auth --local",
    "db:remote": "wrangler d1 migrations apply triad-auth --remote",
    "deploy": "vp run build && vp exec wrangler deploy",
    "dev": "CLOUDFLARE_ENV=local vp exec astro dev",
    "keygen": "node scripts/generate-key.mjs",
    "preview": "vp run build && vp exec astro preview"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@fontsource-variable/archivo": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "astro": "^7.0.7",
    "hono": "^4.10.2",
    "jose": "^6.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "eslint-plugin-perfectionist": "^5.10.0",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.110.0"
  },
  "packageManager": "pnpm@11.11.0"
}
