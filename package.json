{
  "name": "triad-auth-broker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build && wrangler dev --var ISSUER:http://localhost:8787",
    "build": "astro build && node scripts/generate-csp-hashes.mjs",
    "deploy": "pnpm build && wrangler deploy",
    "db:local": "wrangler d1 migrations apply triad-auth --local",
    "db:remote": "wrangler d1 migrations apply triad-auth --remote",
    "keygen": "node scripts/generate-key.mjs",
    "check:config": "node scripts/check-config.mjs",
    "check:deploy": "wrangler deploy --dry-run",
    "check": "pnpm typecheck && pnpm build && pnpm test && pnpm check:deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/archivo": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "astro": "^7.0.7",
    "hono": "^4.10.2",
    "jose": "^6.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "typescript": "^7.0.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.24.3"
  }
}
