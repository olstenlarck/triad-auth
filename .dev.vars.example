# Provider credentials. Configure at least one complete ID/secret pair and leave unused pairs empty.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Paste the one-line JSON emitted by `vp run keygen`; quote it in .dev.vars.
SIGNING_PRIVATE_JWK=

# Preserve the existing account identifiers by using the current PAIRWISE_SECRET value during rollout.
IDENTIFIER_SECRET=

# One-line JSON: {"active":"current","keys":{"current":"at least 32 characters"},"legacy":"old pairwise secret during rollout"}
CLAIMS_ENCRYPTION_KEYRING=

# Use an independent value of at least 32 high-entropy characters.
RATE_LIMIT_SECRET=
