# Provider credentials. Configure at least one complete ID/secret pair and leave unused pairs empty.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Insert one or two JWKs from `vp run keygen`; quote the complete one-line keyring in .dev.vars.
SIGNING_KEYRING=

# Use at least 32 high-entropy characters, for example output from `openssl rand -base64 32`.
PAIRWISE_SECRET=
