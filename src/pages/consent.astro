---
import Shell from "../components/Shell.astro";
---

<Shell title="Authorize app | Triad" mode="product">
  <section class="transaction shell narrow" aria-labelledby="consent-title">
    <div class="transaction-head">
      <p>IDENTITY HANDSHAKE</p>
      <h1 id="consent-title">CHECK THE<br /><span>CONNECTION.</span></h1>
      <p id="consent-summary" class="lede">Loading the authorization request...</p>
    </div>

    <div id="consent-panel" class="transaction-panel" aria-live="polite" aria-busy="true">
      <div class="request-party">
        <div class="app-glyph" aria-hidden="true">?</div>
        <div><span>APPLICATION</span><strong id="client-name">LOADING...</strong></div>
        <div><span>PROVIDER</span><strong id="provider-name">PENDING</strong></div>
      </div>
      <div class="disclosure-list">
        <div><span>APP-SCOPED ID</span><strong>pairwise_sub</strong><small>Unique to this application. Different client, different value.</small></div>
        <div><span>BROKER ACCOUNT</span><strong>account_sub</strong><small>Stable across Triad clients and correlates this broker account between them.</small></div>
        <div><span>GLOBAL PROVIDER ID</span><strong>provider_sub</strong><small>GitHub-global and globally correlatable across Triad clients that receive it.</small></div>
        <div><span>PROFILE DATA</span><strong>NONE</strong><small>No email, name, avatar, or GitHub access token.</small></div>
      </div>
    </div>

    <p id="consent-error" class="error-message" role="alert" hidden></p>
    <div class="actions transaction-actions">
      <button id="approve" class="button primary" type="button" disabled>CONTINUE WITH GITHUB</button>
      <button id="deny" class="button secondary" type="button" disabled>DENY REQUEST</button>
    </div>
    <p class="fine-print">The app receives signed identifiers, not access to your GitHub account.</p>
  </section>

  <script>
    const request = new URLSearchParams(location.search).get("request");
    const panel = document.querySelector<HTMLElement>("#consent-panel")!;
    const approve = document.querySelector<HTMLButtonElement>("#approve")!;
    const deny = document.querySelector<HTMLButtonElement>("#deny")!;
    const error = document.querySelector<HTMLElement>("#consent-error")!;
    let csrfToken = "";

    function fail(message: string) {
      error.textContent = message;
      error.hidden = false;
      panel.setAttribute("aria-busy", "false");
      approve.disabled = true;
      deny.disabled = true;
    }

    async function act(action: "approve" | "deny") {
      if (!request || !csrfToken) return fail("This request is not ready. Reload the page to inspect it again.");
      approve.disabled = true;
      deny.disabled = true;
      approve.textContent = action === "approve" ? "OPENING GITHUB" : "DENYING REQUEST";
      try {
        const response = await fetch(`/api/consent/${encodeURIComponent(request)}/${action}`, {
          method: "POST",
          headers: { "content-type": "application/x-www-form-urlencoded" },
          body: new URLSearchParams({ csrf_token: csrfToken }),
        });
        const body = await response.json() as { redirect_to?: string; error_description?: string };
        if (!response.ok || !body.redirect_to) return fail(body.error_description ?? "This request could not be completed. Reload and try again.");
        location.assign(body.redirect_to);
      } catch {
        fail("The broker could not complete this request. Reload the page to inspect it again.");
      }
    }

    if (!request) {
      fail("This authorization request is missing its ticket.");
    } else {
      fetch(`/api/consent/${encodeURIComponent(request)}`)
        .then(async (response) => ({
          response,
          body: await response.json() as {
            client_name?: string;
            provider?: string;
            csrf_token?: string;
            error_description?: string;
          },
        }))
        .then(({ response, body }) => {
          if (!response.ok || !body.csrf_token) return fail(body.error_description ?? "This authorization request expired.");
          csrfToken = body.csrf_token;
          document.querySelector("#client-name")!.textContent = body.client_name ?? "UNKNOWN APP";
          document.querySelector("#provider-name")!.textContent = "GITHUB";
          document.querySelector("#consent-summary")!.textContent = `${body.client_name ?? "This app"} wants to identify you through GitHub.`;
          document.querySelector(".app-glyph")!.textContent = (body.client_name ?? "A").slice(0, 1).toUpperCase();
          panel.setAttribute("aria-busy", "false");
          approve.disabled = false;
          deny.disabled = false;
        })
        .catch(() => fail("The broker could not load this request."));
    }
    approve.addEventListener("click", () => act("approve"));
    deny.addEventListener("click", () => act("deny"));
  </script>
</Shell>
