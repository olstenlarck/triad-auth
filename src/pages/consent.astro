---
import Shell from "../components/Shell.astro";
---

<Shell title="Authorize app | Triad" mode="product">
  <section class="transaction shell narrow" aria-labelledby="consent-title">
    <div class="transaction-head">
      <p>IDENTITY HANDSHAKE</p>
      <h1 id="consent-title">CHECK THE<br /><span>CONNECTION.</span></h1>
      <p id="consent-summary" class="lede">Loading the authorization request...</p>
    </div>

    <div id="consent-panel" class="transaction-panel" aria-live="polite" aria-busy="true">
      <div class="request-party">
        <div class="app-glyph" aria-hidden="true">?</div>
        <div><span>APPLICATION</span><strong id="client-name">LOADING...</strong></div>
        <div><span>PROVIDER</span><strong id="provider-name">PENDING</strong></div>
      </div>
      <div id="consent-disclosures" class="disclosure-list"></div>
    </div>

    <p id="consent-error" class="error-message" role="alert" hidden></p>
    <div class="actions transaction-actions">
      <button id="approve" class="button primary" type="button" disabled>APPROVE REQUEST</button>
      <button id="deny" class="button secondary" type="button" disabled>DENY REQUEST</button>
      <a id="consent-restart" class="button secondary" href="/demo/" hidden>RETURN TO DEMO</a>
    </div>
    <p class="fine-print">
      Approval shares every claim listed above. The app never receives the upstream access token.
      Triad stores approved scope names. Claims become non-exchangeable at expiry. Physical encrypted-row deletion is bounded, traffic-driven cleanup and can occur later.
    </p>
  </section>

  <script>
    const request = new URLSearchParams(location.search).get("request");
    const panel = document.querySelector<HTMLElement>("#consent-panel")!;
    const approve = document.querySelector<HTMLButtonElement>("#approve")!;
    const deny = document.querySelector<HTMLButtonElement>("#deny")!;
    const error = document.querySelector<HTMLElement>("#consent-error")!;
    const restart = document.querySelector<HTMLAnchorElement>("#consent-restart")!;
    const disclosures = document.querySelector<HTMLElement>("#consent-disclosures")!;
    let csrfToken = "";

    const disclosureDetails: Record<string, Array<[string, string, string]>> = {
      openid: [
        ["APP-SCOPED ID", "pairwise_sub", "Unique to this application. Different client, different value."],
        ["BROKER ACCOUNT", "account_sub", "Stable across Triad clients and correlates this broker account between them."],
        ["PROVIDER-GLOBAL ID", "provider_sub", "Correlatable across authorized Triad clients without exposing the upstream ID."],
      ],
      email: [["EMAIL + VERIFICATION STATUS", "email + email_verified", "Mutable profile data. Never use it as an identity key."]],
      handle: [["PROVIDER HANDLE", "preferred_username", "The account handle reported by the selected provider."]],
      name: [["DISPLAY NAME", "name", "The display name reported by the selected provider."]],
      avatar: [["AVATAR URL", "picture", "The profile image URL reported by the selected provider."]],
    };

    function renderDisclosures(scopes: string[]) {
      disclosures.replaceChildren();
      for (const scope of scopes) {
        const rows = disclosureDetails[scope];
        if (!rows) throw new Error("This request contains an unsupported claim.");
        for (const [label, claim, description] of rows) {
          const row = document.createElement("div");
          const labelNode = document.createElement("span");
          const claimNode = document.createElement("strong");
          const descriptionNode = document.createElement("small");
          labelNode.textContent = label;
          claimNode.textContent = claim;
          descriptionNode.textContent = description;
          row.append(labelNode, claimNode, descriptionNode);
          disclosures.append(row);
        }
      }
    }

    function resetActions() {
      approve.textContent = "APPROVE REQUEST";
      deny.textContent = "DENY REQUEST";
    }

    function fail(message: string) {
      resetActions();
      error.textContent = message;
      error.hidden = false;
      restart.hidden = false;
      panel.setAttribute("aria-busy", "false");
      approve.disabled = true;
      deny.disabled = true;
    }

    async function act(action: "approve" | "deny") {
      if (!request || !csrfToken) return fail("This request is not ready. Reload the page to inspect it again.");
      approve.disabled = true;
      deny.disabled = true;
      error.hidden = true;
      restart.hidden = true;
      const active = action === "approve" ? approve : deny;
      active.textContent = action === "approve" ? "APPROVING REQUEST" : "DENYING REQUEST";
      try {
        const response = await fetch(`/api/consent/${encodeURIComponent(request)}/${action}`, {
          method: "POST",
          headers: { "content-type": "application/x-www-form-urlencoded" },
          body: new URLSearchParams({ csrf_token: csrfToken }),
        });
        const body = await response.json() as { redirect_to?: string; error_description?: string };
        if (!response.ok || !body.redirect_to) return fail(body.error_description ?? "This request could not be completed. Reload and try again.");
        location.assign(body.redirect_to);
      } catch {
        fail("The broker could not complete this request. Reload the page to inspect it again.");
      }
    }

    if (!request) {
      fail("This authorization request is missing its ticket.");
    } else {
      fetch(`/api/consent/${encodeURIComponent(request)}`)
        .then(async (response) => ({
          response,
          body: await response.json() as {
            client_name?: string;
            provider?: string;
            scopes?: string[];
            csrf_token?: string;
            error_description?: string;
          },
        }))
        .then(({ response, body }) => {
          if (
            !response.ok
            || !body.csrf_token
            || !body.provider
            || !["google", "github", "twitter"].includes(body.provider)
            || !Array.isArray(body.scopes)
            || !body.scopes.includes("openid")
          ) return fail(body.error_description ?? "This authorization request expired.");
          csrfToken = body.csrf_token;
          document.querySelector("#client-name")!.textContent = body.client_name ?? "UNKNOWN APP";
          document.querySelector("#provider-name")!.textContent = body.provider.toUpperCase();
          document.querySelector("#consent-summary")!.textContent = `${body.client_name ?? "This app"} requests the mandatory claims below through ${body.provider}.`;
          document.querySelector(".app-glyph")!.textContent = (body.client_name ?? "A").slice(0, 1).toUpperCase();
          renderDisclosures(body.scopes);
          panel.setAttribute("aria-busy", "false");
          approve.disabled = false;
          deny.disabled = false;
        })
        .catch(() => fail("The broker could not load this request."));
    }
    approve.addEventListener("click", () => act("approve"));
    deny.addEventListener("click", () => act("deny"));
  </script>
</Shell>
