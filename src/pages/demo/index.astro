---
import Shell from "../../components/Shell.astro";
---

<Shell
  title="Try the broker | Triad"
  description="Run Triad's authorization-code PKCE and device flows, then inspect a verified ID token."
  mode="product"
>
  <section class="transaction shell demo" aria-labelledby="demo-title">
    <div class="transaction-head demo-head">
      <p>TRY THE BROKER</p>
      <h1 id="demo-title">TWO FLOWS.<br /><span>ONE IDENTITY.</span></h1>
      <p class="lede">
        Choose an enabled provider and the optional claims this demo client requests. Both paths finish with the same locally verified identity contract.
      </p>
    </div>

    <section class="demo-request" aria-labelledby="demo-request-title">
      <div class="demo-request-heading">
        <h2 id="demo-request-title">CONFIGURE THE CLIENT REQUEST</h2>
        <p>Optional claims default off. Any claim selected here is mandatory for this transaction and shown again before approval.</p>
      </div>
      <fieldset id="provider-fieldset" disabled>
        <legend>UPSTREAM PROVIDER</legend>
        <div id="provider-options" class="provider-selector">
          <template id="provider-option-template">
            <label>
              <input type="radio" name="demo-provider" />
              <span></span>
            </label>
          </template>
        </div>
      </fieldset>
      <fieldset id="scope-fieldset" disabled>
        <legend>OPTIONAL CLAIM REQUEST</legend>
        <div class="scope-selector">
          <label><input type="checkbox" name="demo-scope" value="email" /><span>EMAIL<small>email + email_verified</small></span></label>
          <label><input type="checkbox" name="demo-scope" value="handle" /><span>HANDLE<small>preferred_username</small></span></label>
          <label><input type="checkbox" name="demo-scope" value="name" /><span>NAME<small>name</small></span></label>
          <label><input type="checkbox" name="demo-scope" value="avatar" /><span>AVATAR<small>picture</small></span></label>
        </div>
      </fieldset>
      <div class="control-feedback demo-provider-feedback">
        <p id="provider-status" class="control-status" aria-live="polite">Loading enabled providers...</p>
        <button id="provider-retry" class="button secondary" type="button" hidden>RETRY PROVIDERS</button>
      </div>
    </section>

    <div class="demo-grid">
      <section class="demo-bay" aria-labelledby="browser-demo-title">
        <div class="demo-bay-head">
          <div>
            <span class="demo-index">01 / BROWSER</span>
            <h2 id="browser-demo-title">AUTHORIZATION CODE + PKCE</h2>
          </div>
          <span class="status-mark" aria-hidden="true"></span>
        </div>
        <p>Triad creates a 64-byte verifier, sends only its S256 challenge, and checks state before exchanging the returned code.</p>
        <dl class="protocol-list">
          <div><dt>CLIENT</dt><dd>triad-demo</dd></div>
          <div><dt>PROVIDER</dt><dd id="browser-provider">loading</dd></div>
          <div><dt>VERIFICATION</dt><dd>ES256 + JWKS</dd></div>
        </dl>
        <p id="browser-status" class="demo-status" aria-live="polite">Loading enabled providers.</p>
        <button id="browser-start" class="button primary demo-action" type="button" disabled>START BROWSER FLOW</button>
      </section>

      <section class="demo-bay" aria-labelledby="device-demo-title">
        <div class="demo-bay-head">
          <div>
            <span class="demo-index">02 / DEVICE</span>
            <h2 id="device-demo-title">DEVICE AUTHORIZATION</h2>
          </div>
          <span class="status-mark" aria-hidden="true"></span>
        </div>
        <p>Start a device grant, approve the displayed code in another browser tab, and leave this page open while it polls.</p>
        <div id="device-instructions" class="device-ticket" hidden>
          <span>USER CODE</span>
          <strong id="demo-user-code"></strong>
          <a id="verification-link" class="text-link" href="/device/verify/" target="_blank" rel="noopener">OPEN VERIFICATION PAGE ↗</a>
          <small id="device-expiry"></small>
        </div>
        <p id="device-status" class="demo-status" aria-live="polite">No device request is active.</p>
        <button id="device-start" class="button primary demo-action" type="button" disabled>START DEVICE FLOW</button>

        <section id="device-identity" class="verified-result" aria-labelledby="device-result-title" hidden>
          <div class="verified-head">
            <span class="verified-symbol" aria-hidden="true">✓</span>
            <div><span>SIGNATURE VALID</span><h3 id="device-result-title" tabindex="-1">VERIFIED IDENTITY</h3></div>
          </div>
          <dl class="verified-claims">
            <div><dt>pairwise_sub</dt><dd id="device-pairwise"></dd><small>App-scoped. Different for every client.</small></div>
            <div><dt>account_sub</dt><dd id="device-account"></dd><small>Broker-global. Correlates this account across Triad clients.</small></div>
            <div><dt>provider_sub</dt><dd id="device-provider"></dd><small>Provider-global and correlatable across Triad clients that receive it.</small></div>
          </dl>
          <section id="device-profile" class="verified-profile" aria-labelledby="device-profile-title" hidden>
            <h4 id="device-profile-title">VERIFIED OPTIONAL CLAIMS</h4>
            <dl id="device-profile-claims"></dl>
          </section>
        </section>
      </section>
    </div>
  </section>

  <script>
    import {
      createPkce,
      canonicalScopeRequest,
      devicePollDecision,
      fetchDiscovery,
      fetchProviderCapabilities,
      verifyIdentityToken,
      type ProviderCapability,
      type VerifiedProfile,
      type VerifiedIdentity,
    } from "../../scripts/demo-protocol";

    const clientId = "triad-demo";
    const deviceGrantType = "urn:ietf:params:oauth:grant-type:device_code";
    const browserStart = document.querySelector<HTMLButtonElement>("#browser-start")!;
    const browserStatus = document.querySelector<HTMLElement>("#browser-status")!;
    const deviceStart = document.querySelector<HTMLButtonElement>("#device-start")!;
    const deviceStatus = document.querySelector<HTMLElement>("#device-status")!;
    const deviceInstructions = document.querySelector<HTMLElement>("#device-instructions")!;
    const deviceIdentity = document.querySelector<HTMLElement>("#device-identity")!;
    const providerFieldset = document.querySelector<HTMLFieldSetElement>("#provider-fieldset")!;
    const scopeFieldset = document.querySelector<HTMLFieldSetElement>("#scope-fieldset")!;
    const providerOptions = document.querySelector<HTMLElement>("#provider-options")!;
    const providerStatus = document.querySelector<HTMLElement>("#provider-status")!;
    const providerRetry = document.querySelector<HTMLButtonElement>("#provider-retry")!;
    const providerTemplate = document.querySelector<HTMLTemplateElement>("#provider-option-template")!;
    const scopeInputs = [...document.querySelectorAll<HTMLInputElement>('input[name="demo-scope"]')];
    let providerCapabilities: ProviderCapability[] = [];
    let activeFlow: "browser" | "device" | null = null;
    let pollTimer: number | undefined;
    let expiresAt = 0;
    let intervalMs = 5_000;
    let activeDeviceCode = "";
    let tokenEndpoint = "";
    let stopped = false;
    let deviceController = new AbortController();

    function selectedCapability(): ProviderCapability | undefined {
      const selected = document.querySelector<HTMLInputElement>('input[name="demo-provider"]:checked');
      return providerCapabilities.find((provider) => provider.id === selected?.value);
    }

    function selectedScopeRequest(provider: ProviderCapability): string {
      return canonicalScopeRequest(provider, scopeInputs.filter((input) => input.checked).map((input) => input.value));
    }

    function updateRequestControls(updateStatus = true) {
      const selectedProvider = selectedCapability();
      const requestLocked = activeFlow !== null;
      for (const input of scopeInputs) {
        const supported = selectedProvider?.scopes.some((scope) => scope === input.value) ?? false;
        input.disabled = requestLocked || !supported;
        if (!supported) input.checked = false;
      }
      const providerName = selectedProvider?.id.toUpperCase() ?? "PROVIDER";
      document.querySelector<HTMLElement>("#browser-provider")!.textContent = selectedProvider?.id ?? "unavailable";
      browserStart.textContent = `SIGN IN WITH ${providerName}`;
      providerFieldset.disabled = activeFlow !== null;
      scopeFieldset.disabled = activeFlow !== null;
      browserStart.disabled = activeFlow !== null || !selectedProvider;
      deviceStart.disabled = activeFlow !== null || !selectedProvider;
      if (selectedProvider && updateStatus && !requestLocked) {
        message(browserStatus, `Ready to open ${selectedProvider.id} in this window.`);
        message(deviceStatus, "No device request is active.");
      }
    }

    function beginFlow(flow: "browser" | "device"): boolean {
      if (activeFlow !== null) return false;
      activeFlow = flow;
      updateRequestControls(false);
      return true;
    }

    function finishFlow(flow: "browser" | "device") {
      if (activeFlow !== flow) return;
      activeFlow = null;
      updateRequestControls(false);
    }

    async function loadProviderControls() {
      providerRetry.hidden = true;
      providerRetry.disabled = true;
      providerStatus.textContent = "Loading enabled providers...";
      providerStatus.dataset.tone = "working";
      providerFieldset.disabled = true;
      scopeFieldset.disabled = true;
      browserStart.disabled = true;
      deviceStart.disabled = true;
      providerCapabilities = [];
      providerOptions.querySelectorAll("label").forEach((option) => option.remove());
      try {
        providerCapabilities = await fetchProviderCapabilities();
        if (!providerCapabilities.length) throw new Error("No providers are enabled.");
        for (const provider of providerCapabilities) {
          const option = providerTemplate.content.firstElementChild!.cloneNode(true) as HTMLLabelElement;
          const input = option.querySelector<HTMLInputElement>("input")!;
          const label = option.querySelector<HTMLElement>("span")!;
          input.value = provider.id;
          input.checked = provider === providerCapabilities[0];
          label.textContent = provider.id.toUpperCase();
          providerOptions.insertBefore(option, providerTemplate);
        }
        providerFieldset.disabled = false;
        scopeFieldset.disabled = false;
        providerStatus.textContent = "Only providers enabled by this Triad deployment appear here.";
        providerRetry.disabled = false;
        updateRequestControls();
      } catch {
        providerStatus.textContent = "Enabled providers could not be loaded.";
        providerStatus.dataset.tone = "error";
        message(browserStatus, "The provider list could not be loaded. Reload and try again.", "error");
        message(deviceStatus, "The provider list could not be loaded. Reload and try again.", "error");
        providerRetry.hidden = false;
        providerRetry.disabled = false;
      }
    }

    function renderProfileClaims(container: HTMLElement, profile: VerifiedProfile) {
      const claims: Array<[string, string | boolean | undefined]> = [
        ["email", profile.email],
        ["email_verified", profile.emailVerified],
        ["preferred_username", profile.handle],
        ["name", profile.name],
        ["picture", profile.avatar],
      ];
      container.replaceChildren();
      for (const [claim, value] of claims) {
        if (value === undefined) continue;
        const row = document.createElement("div");
        const term = document.createElement("dt");
        const description = document.createElement("dd");
        term.textContent = claim;
        description.textContent = String(value);
        row.append(term, description);
        container.append(row);
      }
      container.parentElement!.hidden = !container.childElementCount;
    }

    function message(element: HTMLElement, text: string, tone: "working" | "error" | "success" = "working") {
      element.textContent = text;
      element.dataset.tone = tone;
    }

    function stopPolling() {
      if (pollTimer !== undefined) window.clearTimeout(pollTimer);
      pollTimer = undefined;
    }

    function stopDeviceFlow() {
      stopped = true;
      stopPolling();
      deviceController.abort();
    }

    function renderIdentity(identity: VerifiedIdentity) {
      document.querySelector<HTMLElement>("#device-pairwise")!.textContent = identity.pairwiseSub;
      document.querySelector<HTMLElement>("#device-account")!.textContent = identity.accountSub;
      document.querySelector<HTMLElement>("#device-provider")!.textContent = identity.providerSub;
      renderProfileClaims(document.querySelector<HTMLElement>("#device-profile-claims")!, identity.profile);
      deviceIdentity.hidden = false;
      message(deviceStatus, "Signature, issuer, audience, expiry, and identity claims verified.", "success");
      document.querySelector<HTMLElement>("#device-result-title")!.focus();
    }

    function schedulePoll() {
      if (stopped) return;
      const remaining = expiresAt - Date.now();
      if (remaining <= 0) {
        message(deviceStatus, "This device code expired. Start a new device flow.", "error");
        deviceStart.textContent = "START NEW DEVICE FLOW";
        stopDeviceFlow();
        finishFlow("device");
        return;
      }
      pollTimer = window.setTimeout(pollDevice, Math.min(intervalMs, remaining));
    }

    async function pollDevice() {
      if (stopped) return;
      if (!activeDeviceCode || Date.now() >= expiresAt) {
        message(deviceStatus, "This device code expired. Start a new device flow.", "error");
        deviceStart.textContent = "START NEW DEVICE FLOW";
        stopDeviceFlow();
        finishFlow("device");
        return;
      }
      try {
        const response = await fetch(tokenEndpoint, {
          method: "POST",
          headers: { "content-type": "application/x-www-form-urlencoded" },
          signal: deviceController.signal,
          body: new URLSearchParams({
            grant_type: deviceGrantType,
            client_id: clientId,
            device_code: activeDeviceCode,
          }),
        });
        const body = await response.json() as { id_token?: string; error?: string };
        if (stopped) return;
        if (response.ok && body.id_token) {
          stopPolling();
          message(deviceStatus, "Token received. Verifying its signature and claims.");
          const verified = await verifyIdentityToken(
            body.id_token,
            clientId,
            location.origin,
            deviceController.signal,
          );
          if (stopped) return;
          stopDeviceFlow();
          renderIdentity(verified);
          deviceStart.textContent = "START NEW DEVICE FLOW";
          finishFlow("device");
          return;
        }

        if (body.error === "authorization_pending" || body.error === "slow_down") {
          const decision = devicePollDecision(body.error, intervalMs);
          intervalMs = decision.intervalMs;
          message(deviceStatus, decision.message);
          if (stopped) return;
          schedulePoll();
          return;
        }
        const decision = devicePollDecision(body.error ?? "invalid_grant", intervalMs);
        message(deviceStatus, decision.message, "error");
        deviceStart.textContent = "START NEW DEVICE FLOW";
        stopDeviceFlow();
        finishFlow("device");
      } catch (reason) {
        if (stopped || (reason instanceof DOMException && reason.name === "AbortError")) return;
        message(deviceStatus, "The device flow could not be verified. Check your connection and start again.", "error");
        deviceStart.textContent = "START NEW DEVICE FLOW";
        stopDeviceFlow();
        finishFlow("device");
      }
    }

    browserStart.addEventListener("click", async () => {
      const selectedProvider = selectedCapability();
      if (!selectedProvider) return;
      const requestedScope = selectedScopeRequest(selectedProvider);
      if (!beginFlow("browser")) return;
      browserStart.textContent = "PREPARING PKCE";
      message(browserStatus, "Loading broker discovery and creating a one-time PKCE request.");
      try {
        const [discovery, pkce] = await Promise.all([fetchDiscovery(), createPkce()]);
        sessionStorage.setItem("triad_demo_verifier", pkce.verifier);
        sessionStorage.setItem("triad_demo_state", pkce.state);
        const callback = `${location.origin}/demo/callback/`;
        const authorization = new URL(discovery.authorization_endpoint);
        authorization.search = new URLSearchParams({
          client_id: clientId,
          redirect_uri: callback,
          response_type: "code",
          provider: selectedProvider.id,
          scope: requestedScope,
          state: pkce.state,
          code_challenge: pkce.challenge,
          code_challenge_method: "S256",
        }).toString();
        location.assign(authorization);
      } catch {
        message(browserStatus, "The authorization request could not be started. Check the broker and try again.", "error");
        finishFlow("browser");
      }
    });

    deviceStart.addEventListener("click", async () => {
      const selectedProvider = selectedCapability();
      if (!selectedProvider) return;
      const requestedScope = selectedScopeRequest(selectedProvider);
      if (!beginFlow("device")) return;
      stopped = false;
      deviceController = new AbortController();
      deviceStart.disabled = true;
      deviceStart.textContent = "REQUESTING CODE";
      deviceIdentity.hidden = true;
      deviceInstructions.hidden = true;
      message(deviceStatus, "Requesting a one-time device code.");
      try {
        const discovery = await fetchDiscovery(location.origin, deviceController.signal);
        if (stopped) return;
        const response = await fetch(discovery.device_authorization_endpoint, {
          method: "POST",
          headers: { "content-type": "application/x-www-form-urlencoded" },
          signal: deviceController.signal,
          body: new URLSearchParams({
            client_id: clientId,
            provider: selectedProvider.id,
            scope: requestedScope,
          }),
        });
        const body = await response.json() as {
          device_code?: string;
          user_code?: string;
          verification_uri_complete?: string;
          expires_in?: number;
          interval?: number;
          error_description?: string;
        };
        if (stopped) return;
        if (!response.ok || !body.device_code || !body.user_code || !body.verification_uri_complete
          || typeof body.expires_in !== "number" || typeof body.interval !== "number") {
          throw new Error(body.error_description ?? "invalid device response");
        }
        activeDeviceCode = body.device_code;
        tokenEndpoint = discovery.token_endpoint;
        intervalMs = Math.max(1, body.interval) * 1_000;
        expiresAt = Date.now() + body.expires_in * 1_000;
        document.querySelector<HTMLElement>("#demo-user-code")!.textContent = body.user_code;
        const verificationLink = document.querySelector<HTMLAnchorElement>("#verification-link")!;
        verificationLink.href = body.verification_uri_complete;
        document.querySelector<HTMLElement>("#device-expiry")!.textContent = `Expires in ${Math.ceil(body.expires_in / 60)} minutes`;
        deviceInstructions.hidden = false;
        deviceStart.textContent = "FLOW IN PROGRESS";
        message(deviceStatus, "Waiting for browser approval.");
        if (stopped) return;
        schedulePoll();
      } catch (reason) {
        if (stopped || (reason instanceof DOMException && reason.name === "AbortError")) return;
        message(deviceStatus, "A device code could not be issued. Check the broker and try again.", "error");
        deviceStart.textContent = "START DEVICE FLOW";
        stopDeviceFlow();
        finishFlow("device");
      }
    });

    providerOptions.addEventListener("change", () => updateRequestControls());
    providerRetry.addEventListener("click", () => { void loadProviderControls(); });
    window.addEventListener("pagehide", stopDeviceFlow);
    void loadProviderControls();
  </script>
</Shell>
