---
import Shell from "../components/Shell.astro";
---

<Shell title="Your identity | Triad" mode="product">
  <section class="account shell" aria-labelledby="account-title">
    <div class="account-heading">
      <p>YOUR BROKER SESSION</p>
      <h1 id="account-title">YOUR<br /><span>IDENTITY.</span></h1>
      <p id="account-summary" class="lede">Loading your broker session...</p>
    </div>

    <div id="signed-out" class="signed-out" hidden>
      <p>Choose an enabled provider to inspect your broker account and authorized applications.</p>
      <div class="control-feedback">
        <div id="account-provider-actions" class="actions" aria-live="polite">Loading enabled providers...</div>
        <button id="account-provider-retry" class="button secondary" type="button" hidden>RETRY PROVIDERS</button>
      </div>
    </div>

    <div id="account-content" hidden>
      <section class="account-panel" aria-labelledby="ids-title">
        <h2 id="ids-title">IDENTIFIERS</h2>
        <dl class="account-ids">
          <div><dt>ACCOUNT SUB</dt><dd id="account-sub">PENDING</dd></div>
          <div><dt>LINKED IDENTITIES</dt><dd id="identity-list">PENDING</dd></div>
        </dl>
      </section>

      <section class="account-panel" aria-labelledby="apps-title">
        <div class="panel-heading"><h2 id="apps-title">AUTHORIZED APPS</h2><span id="app-count">0</span></div>
        <div id="authorized-apps" class="authorized-apps"></div>
      </section>
      <div class="actions">
        <button id="logout" class="button danger" type="button">SIGN OUT</button>
      </div>
    </div>
    <p id="me-error" class="error-message" role="alert" hidden></p>
  </section>

  <script>
    import { fetchProviderCapabilities } from "../scripts/demo-protocol";

    const content = document.querySelector<HTMLElement>("#account-content")!;
    const signedOut = document.querySelector<HTMLElement>("#signed-out")!;
    const error = document.querySelector<HTMLElement>("#me-error")!;
    const logout = document.querySelector<HTMLButtonElement>("#logout")!;
    const appCount = document.querySelector<HTMLElement>("#app-count")!;
    const list = document.querySelector<HTMLElement>("#authorized-apps")!;
    const providerActions = document.querySelector<HTMLElement>("#account-provider-actions")!;
    const providerRetry = document.querySelector<HTMLButtonElement>("#account-provider-retry")!;
    let csrfToken = "";
    let remainingClients = 0;
    let loadGeneration = 0;
    let loadController: AbortController | null = null;
    let providerController: AbortController | null = null;

    function setMutationControls(disabled: boolean) {
      logout.disabled = disabled;
      list.querySelectorAll<HTMLButtonElement>("button").forEach((button) => { button.disabled = disabled; });
    }

    function showError(reason: unknown, fallback: string) {
      error.textContent = reason instanceof Error ? reason.message : fallback;
      error.hidden = false;
    }

    async function responseError(response: Response, fallback: string): Promise<Error> {
      try {
        const body = await response.json() as { error_description?: string; error?: string };
        return new Error(body.error_description ?? body.error ?? fallback);
      } catch {
        return new Error(fallback);
      }
    }

    async function takeCsrfToken(): Promise<string> {
      if (!csrfToken) await load();
      if (!csrfToken) throw new Error("Could not refresh account security state.");
      const token = csrfToken;
      csrfToken = "";
      return token;
    }

    async function recoverAccount(reason: unknown, fallback: string) {
      csrfToken = "";
      showError(reason, fallback);
      try {
        await load();
        showError(reason, fallback);
      } catch (reloadReason) {
        showError(reloadReason, fallback);
      }
    }

    async function revokeClient(clientId: string, row: HTMLElement) {
      setMutationControls(true);
      try {
        const token = await takeCsrfToken();
        setMutationControls(true);
        const revoked = await fetch(`/api/me/clients/${encodeURIComponent(clientId)}`, {
          method: "DELETE",
          headers: { "content-type": "application/x-www-form-urlencoded" },
          body: new URLSearchParams({ csrf_token: token }),
        });
        if (!revoked.ok) throw await responseError(revoked, "Could not revoke this authorization.");
        const next = await revoked.json() as { csrf_token?: string };
        if (!next.csrf_token) throw new Error("Authorization changed, but security state could not be refreshed.");
        csrfToken = next.csrf_token;
        row.remove();
        appCount.textContent = String(--remainingClients);
        if (!remainingClients) list.innerHTML = `<p class="empty-state">No downstream applications are authorized.</p>`;
      } catch (reason) {
        await recoverAccount(reason, "Could not revoke this authorization.");
      } finally {
        setMutationControls(false);
      }
    }

    async function logoutAccount() {
      setMutationControls(true);
      try {
        const token = await takeCsrfToken();
        setMutationControls(true);
        const response = await fetch("/session/logout", {
          method: "POST",
          headers: { "content-type": "application/x-www-form-urlencoded" },
          body: new URLSearchParams({ csrf_token: token }),
        });
        if (!response.ok) throw await responseError(response, "Could not sign out.");
        location.reload();
      } catch (reason) {
        await recoverAccount(reason, "Could not sign out.");
      } finally {
        setMutationControls(false);
      }
    }

    async function renderProviderActions() {
      providerController?.abort();
      const controller = new AbortController();
      providerController = controller;
      providerActions.textContent = "Loading enabled providers...";
      providerRetry.hidden = true;
      providerRetry.disabled = true;
      try {
        const providers = await fetchProviderCapabilities(location.origin, controller.signal);
        if (!providers.length) throw new Error("No sign-in providers are enabled.");
        providerActions.replaceChildren();
        for (const provider of providers) {
          const link = document.createElement("a");
          link.className = "button primary";
          link.href = `/session/start/${provider.id}`;
          link.textContent = `CONTINUE WITH ${provider.id.toUpperCase()}`;
          providerActions.append(link);
        }
      } catch (reason) {
        if (reason instanceof DOMException && reason.name === "AbortError") return;
        providerActions.textContent = "Sign-in providers could not be loaded.";
        providerRetry.hidden = false;
      } finally {
        if (providerController === controller) {
          providerController = null;
          providerRetry.disabled = false;
        }
      }
    }

    async function load() {
      const generation = ++loadGeneration;
      loadController?.abort();
      const controller = new AbortController();
      loadController = controller;
      csrfToken = "";
      setMutationControls(true);
      try {
        const response = await fetch("/api/me", { signal: controller.signal });
        if (generation !== loadGeneration) return;
        if (response.status === 401) {
          document.querySelector("#account-summary")!.textContent = "No active broker session on this browser.";
          content.hidden = true;
          signedOut.hidden = false;
          list.replaceChildren();
          await renderProviderActions();
          return;
        }
        const body = await response.json() as {
          account_sub?: string;
          identities?: string[];
          clients?: Array<{ client_id: string; name: string; updated_at: number }>;
          csrf_token?: string;
          error?: string;
        };
        if (generation !== loadGeneration) return;
        if (!response.ok) throw new Error(body.error ?? "Could not load your session.");
        if (!body.csrf_token) throw new Error("Account security state is unavailable.");
        document.querySelector("#account-summary")!.textContent = "This is the identity map Triad holds for you.";
        document.querySelector("#account-sub")!.textContent = body.account_sub ?? "NONE";
        document.querySelector("#identity-list")!.textContent = body.identities?.join(" · ") || "NONE";
        const clients = body.clients ?? [];
        csrfToken = body.csrf_token;
        remainingClients = clients.length;
        appCount.textContent = String(remainingClients);
        list.replaceChildren();
        if (!clients.length) list.innerHTML = `<p class="empty-state">No downstream applications are authorized.</p>`;
        for (const client of clients) {
          const row = document.createElement("article");
          row.className = "authorized-app";
          const title = document.createElement("h3");
          title.textContent = client.name;
          const id = document.createElement("code");
          id.textContent = client.client_id;
          const button = document.createElement("button");
          button.className = "button danger";
          button.textContent = "REVOKE";
          button.addEventListener("click", () => { void revokeClient(client.client_id, row); });
          row.append(title, id, button);
          list.append(row);
        }
        signedOut.hidden = true;
        content.hidden = false;
        error.hidden = true;
      } finally {
        if (generation === loadGeneration) {
          loadController = null;
          setMutationControls(false);
        }
      }
    }

    logout.addEventListener("click", () => { void logoutAccount(); });
    providerRetry.addEventListener("click", () => { void renderProviderActions(); });
    window.addEventListener("pagehide", () => {
      loadGeneration++;
      loadController?.abort();
      providerController?.abort();
    });
    load().catch((reason: unknown) => {
      if (!(reason instanceof DOMException && reason.name === "AbortError")) {
        showError(reason, "Could not load your session.");
      }
    });
  </script>
</Shell>
